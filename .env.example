# SBTS Professional environment template
# انسخ الملف إلى .env وعدّل القيم حسب بيئة التشغيل.

NODE_ENV=development
PORT=3000

# MySQL / TiDB connection string
# مثال محلي:
# DATABASE_URL=mysql://root:password@localhost:3306/sbts_professional
DATABASE_URL=

# Production secret: استخدم قيمة عشوائية 32 حرف أو أكثر.
# مثال توليد: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-minimum-32-chars

# Optional app identity
VITE_APP_ID=sbts-professional
OWNER_OPEN_ID=

# Cookie options
# اتركها lax في التشغيل الداخلي. استخدم none فقط عند الحاجة إلى cross-site HTTPS.
COOKIE_SAME_SITE=lax

# Optional built-in services / storage
OAUTH_SERVER_URL=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
