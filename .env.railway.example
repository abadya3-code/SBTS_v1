# Railway App Service Variables
# In Railway, set DATABASE_URL as a reference to the MySQL service:
# DATABASE_URL=${{MySQL.MYSQL_URL}}
DATABASE_URL=${{MySQL.MYSQL_URL}}
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32_CHARACTERS_MINIMUM
NODE_ENV=production
VITE_APP_ID=sbts-railway-pilot-02

# Optional storage/AI variables - leave empty if not used
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
